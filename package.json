    "screenshot",
    "debugging",
    "mcp-server",
    "cursor",
    "claude",
    "windsurf",
    "copilot",
    "ai-coding",
    "code-verification"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/validpilot/ai-verify-mcp"
  },
  "scripts": {
    "start": "node server.js",
    "http": "node start-http.js",
    "cli": "node bin/validpilot.js",
