  "bin": {
    "ai-verify": "bin/validpilot.js",
    "ai-verify-mcp": "bin/validpilot.js"
  },
  "files": [
    "bin/",
    "engines/",
    "hands/",
    "brain/",
    "core/",
    "tools/",
    "rules/",
    "docs/",
    "examples/demo/",
    "server.js",
    "start-http.js",
    "standalone-start.js",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "verify",
    "mcp",
    "validation",
    "proof",
    "evidence",
    "agent",
    "browser-automation",
