  "inputSchema": {
    "type": "object",
    "properties": {
      "baselinePath": { "type": "string" },
      "actualPath": { "type": "string" },
      "beforePath": { "type": "string" },
      "afterPath": { "type": "string" },
      "selector": { "type": "string" },
      "threshold": { "type": "number" },
      "name": { "type": "string" }
    }
  }
}
